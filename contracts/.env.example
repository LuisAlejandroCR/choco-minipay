# Copy to contracts/.env — NEVER commit that file, it holds real private keys.

# Deployment wallet private key (needs CELO for gas). Generate a fresh key; never reuse one
# that has been exposed. Example only — replace with your own key before deploying.
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Keeper address (ERC-8004 agent or your wallet)
KEEPER_ADDRESS=0xYOUR_KEEPER_ADDRESS_HERE

# Celo Mainnet RPC
CELO_RPC_URL=https://forno.celo.org

# Mento V2 Broker (Mainnet — celopedia verified)
MENTO_BROKER_ADDRESS=0x777A8255cA72412f0d706dc03C9D1987306B4CaD
MENTO_PROVIDER_ADDRESS=0x22d9db95E6Ae61c104A7B6F6C78D7993B94ec901

# Mento Exchange IDs (Mainnet: USDC → USDm → cKES)
MENTO_USDC_TO_USDM=0xacc988382b66ee5456086643dcfd9a5ca43dd8f428f6ef22503d8b8013bcffd7
MENTO_USDM_TO_CKES=0x89de88b8eb790de26f4649f543cb6893d93635c728ac857f0926e842fb0d298b

# Token Addresses (Mainnet — celopedia verified)
USDC_ADDRESS=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
USDM_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
KESM_ADDRESS=0x456a3D042C0DbD3db53D5489e98dFb038553B0d0

# Choco Contracts (fill in after deployment)
