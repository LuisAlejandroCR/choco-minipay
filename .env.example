# Public web configuration. Copy to .env locally; never commit real secrets.
# Demo (default for local dev): choco-azure.vercel.app
# Production (set in Vercel env): choco-minipay.vercel.app
VITE_APP_ENV=production
VITE_LIVE_DEMO_URL=https://choco-azure.vercel.app/

# Celo Mainnet
VITE_CELO_NETWORK_NAME=Celo
VITE_CELO_NETWORK_LABEL=Celo Mainnet
VITE_CELO_NETWORK_BADGE=Mainnet
VITE_CELO_CHAIN_ID=42220
VITE_CELO_CHAIN_ID_HEX=0xa4ec
VITE_CELO_RPC_URL=https://forno.celo.org
VITE_BLOCK_EXPLORER_URL=https://celoscan.io
VITE_BLOCK_EXPLORER_TX_URL=https://celoscan.io/tx/
# Blockscout Etherscan-compat API (no key needed). Celoscan V1 is deprecated.
VITE_BLOCK_EXPLORER_API_URL=https://celo.blockscout.com/api

# Contracts. ChocoLedger is the current schedule + audit source.
VITE_LEDGER_ADDRESS=
VITE_LEDGER_DEPLOY_BLOCK=
# Legacy registry fallback, only needed if you still read an old deployment.
VITE_REGISTRY_ADDRESS=
VITE_REGISTRY_DEPLOY_BLOCK=
# Off-chain keeper that executes due schedules (settlement spender the wallet approves). Not a frontend backend.
VITE_SETTLEMENT_SPENDER_ADDRESS=
VITE_DEMO_RECIPIENT_ADDRESS=

# Mento V2 (mainnet) for USDC -> USDm -> KESm send-now. No direct USDC/KESm pool, so the route is two hops.
VITE_MENTO_BROKER_ADDRESS=0x777A8255cA72412f0d706dc03C9D1987306B4CaD
VITE_MENTO_BIPOOL_ADDRESS=0x22d9db95E6Ae61c104A7B6F6C78D7993B94ec901
VITE_MENTO_USDC_USDM_ID=0xacc988382b66ee5456086643dcfd9a5ca43dd8f428f6ef22503d8b8013bcffd7
VITE_MENTO_USDM_CKES_ID=0x89de88b8eb790de26f4649f543cb6893d93635c728ac857f0926e842fb0d298b

# ERC-8004 identity (Celo Mainnet). Registry is fixed; agentId + owner are filled in after registration.
VITE_AGENT_REGISTRY_ADDRESS=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
VITE_AGENT_URI=https://choco-azure.vercel.app/agent.json
VITE_AGENT_ID=
VITE_AGENT_OWNER_ADDRESS=
VITE_AGENT_EXPLORER_URL=https://8004scan.io/agents/celo

# Receipt payments — Supabase persistence and auxiliary contracts.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_AUDIT_CONTRACT_ADDRESS=
# Active gateway used for new send-now transfers.
VITE_CKES_SWAP_CONTRACT_ADDRESS=
# Earliest deploy block among configured ChocoGateway addresses.
VITE_CKES_SWAP_DEPLOY_BLOCK=
# Comma-separated active + legacy gateways to rebuild all send-now movements.
# Example: VITE_CKES_SWAP_CONTRACT_ADDRESSES=0xB555...,0x6567...
VITE_CKES_SWAP_CONTRACT_ADDRESSES=

# Mainnet token addresses. USDC has 6 decimals. KESm/KESm and USDm have 18 decimals.
VITE_USDC_ADDRESS=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
VITE_USDM_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
VITE_KESM_ADDRESS=0x456a3D042C0DbD3db53D5489e98dFb038553B0d0

# Use the USDC fee-currency adapter, not the USDC token address.
VITE_FEE_CURRENCY_ADDRESS=0x2F25deB3848C207fc8E0c34035B3Ba7fC157602B

# Demo quote only. Real settlement should quote through the Mento route.
VITE_KES_PER_USDC=129.39
VITE_SOURCE_ASSET=USDC
VITE_DESTINATION_ASSET=KESm
VITE_BRIDGE_ASSET=USDm
VITE_CORRIDOR_LABEL=US to Kenya
VITE_DESTINATION_COUNTRY=Kenya
VITE_DEFAULT_RECIPIENT_LABEL=recipient
VITE_AGENT_MIN_CONFIDENCE=0.75
# Preferred HH:mm local default for new monthly schedules. Use 04:00 in production.
VITE_DEFAULT_SCHEDULE_TIME=04:00
# Backward-compatible fallback. VITE_DEFAULT_SCHEDULE_TIME wins when both are set.
VITE_DEFAULT_SCHEDULE_HOUR=4
VITE_NETWORK_FEE_LABEL=Network fee
VITE_RETRY_POLICY=3 attempts

# Server-only worker secrets. Set in Vercel, never expose in frontend code.
KEEPER_KEY=
CRON_SECRET=

# Optional ethers v6 demo script, never for frontend builds.
PRIVATE_KEY=

# Local tests only — never commit real keys. Put real values in .env.test.local (gitignored), which
# `npm test` loads via test/load-env.mjs. Wallet-dependent tests skip when TEST_PRIVATE_KEY is unset.
TEST_PRIVATE_KEY=
